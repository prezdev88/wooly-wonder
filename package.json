{
  "name": "pixel-it",
  "private": true,
  "version": "1.1.0",
  "repository": "https://github.com/prezdev88/wooly-wonder",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "start": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && npm run dev:electron\"",
    "build": "tsc -b && vite build",
    "build:electron": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:linux": "vite build && electron-builder --linux",
    "build:win-linux": "vite build && electron-builder -wl",
    "build:all": "vite build && electron-builder -mwl",
    "release": "standard-version",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "i18next": "^26.3.6",
    "jspdf": "^4.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.9"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "standard-version": "^9.5.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.prezdev.woolywonder",
    "productName": "Wooly Wonder",
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icons/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icons/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icons/1024x1024.png"
    }
  }
}
